# ─── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/drive-elite?retryWrites=true&w=majority

# ─── NextAuth ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-32-char-key-here

# ─── Cloudinary ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Admin Seed (run once, then remove) ────────────────────────────────────────
ADMIN_EMAIL=admin@driveelite.com
ADMIN_PASSWORD=Admin@12345

# ─── Optional: Resend (email) ──────────────────────────────────────────────────
# RESEND_API_KEY=re_xxxxxxxxxxxx

# ─── Optional: Upstash Redis (caching) ────────────────────────────────────────
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxx
